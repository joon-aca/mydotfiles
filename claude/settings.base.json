{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/approve-compound-bash.sh",
            "timeout": 3
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(pwd)",
      "Bash(cd:*)",
      "Bash(ls)",
      "Bash(ls:*)",
      "Bash(tree)",
      "Bash(tree:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(realpath:*)",
      "Bash(readlink:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(less:*)",
      "Bash(sed -n:*)",
      "Bash(cut:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "Bash(jq:*)",
      "Bash(grep:*)",
      "Bash(ggrep:*)",
      "Bash(rg:*)",
      "Bash(ag:*)",
      "Bash(ps)",
      "Bash(ps:*)",
      "Bash(pgrep:*)",
      "Bash(top)",
      "Bash(top:*)",
      "Bash(htop)",
      "Bash(htop:*)",
      "Bash(lsof:*)",
      "Bash(netstat:*)",
      "Bash(uname)",
      "Bash(uname:*)",
      "Bash(hostname)",
      "Bash(hostname:*)",
      "Bash(id)",
      "Bash(id:*)",
      "Bash(whoami)",
      "Bash(env)",
      "Bash(printenv)",
      "Bash(printenv:*)",
      "Bash(df)",
      "Bash(df:*)",
      "Bash(du)",
      "Bash(du:*)",
      "Bash(vmstat)",
      "Bash(vmstat:*)",
      "Bash(iostat)",
      "Bash(iostat:*)",
      "Bash(uptime)",
      "Bash(date)",
      "Bash(date:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(dig:*)",
      "Bash(nslookup:*)",
      "Bash(getent:*)",
      "Bash(host:*)",
      "Bash(ping:*)",
      "Bash(traceroute:*)",
      "Bash(tracepath:*)",
      "Bash(docker ps)",
      "Bash(docker ps:*)",
      "Bash(docker images)",
      "Bash(docker images:*)",
      "Bash(docker inspect:*)",
      "Bash(docker logs:*)",
      "Bash(docker stats)",
      "Bash(docker stats:*)",
      "Bash(docker version)",
      "Bash(docker version:*)",
      "Bash(docker info)",
      "Bash(docker info:*)",
      "Bash(docker network ls)",
      "Bash(docker volume ls)",
      "Bash(docker compose ps)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose config)",
      "Bash(docker compose config:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl top:*)",
      "Bash(kubectl version)",
      "Bash(kubectl version:*)",
      "Bash(kubectl cluster-info)",
      "Bash(kubectl cluster-info:*)",
      "Bash(kubectl config current-context)",
      "Bash(kubectl config get-contexts)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx tsc --noEmit:*)",
      "Bash(npx vitest run)",
      "Bash(npx vitest run:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch --list:*)",
      "Bash(git branch --show-current)",
      "Bash(git remote)",
      "Bash(git remote -v)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files)",
      "Bash(git ls-files:*)",
      "Bash(git ls-tree:*)",
      "Bash(git blame:*)",
      "Bash(git grep:*)",
      "Bash(git reflog)",
      "Bash(git cat-file:*)",
      "Bash(git rev-list:*)",
      "Bash(git describe:*)",
      "Bash(git submodule status)",
      "Bash(git submodule status:*)",
      "Bash(git config --get:*)",
      "Bash(git config --get-all:*)",
      "Bash(git config --show-origin:*)",
      "Bash(git config --list)",
      "Bash(git config --list:*)",
      "Bash(* --help)",
      "Bash(* --help:*)",
      "Bash(* --version)",
      "Bash(* --version:*)"
    ],
    "deny": []
  },
  "includeCoAuthoredBy": false,
  "model": "opus",
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "effortLevel": "medium"
}
